CONDA_ENV=vllm-prefetch
VLLM_REPO=/path/to/vllm-cache-prefetch
CUDA_HOME=/usr/local/cuda

SERVICE_NAME=vllm-qwen3vl-32b
CUDA_VISIBLE_DEVICES=2

MODEL_PATH=/path/to/qwen3-vl-32b
SERVED_MODEL_NAME=qwen3vl-32b

HOST=0.0.0.0
PORT=8002

TENSOR_PARALLEL_SIZE=1
DTYPE=bfloat16
GPU_MEMORY_UTILIZATION=0.95
MAX_MODEL_LEN=32768
TRUST_REMOTE_CODE=1
TASK=
ALLOWED_LOCAL_MEDIA_PATH=/path/to/vispage-artifact-release

EXTRA_VLLM_ARGS=

VLLM_AM_ENCODER_CACHE_SIZE=32768
VLLM_AM_ENCODER_CACHE_RESERVE=8192
VLLM_AM_ENCODER_CPU_CACHE_GB=16

RUN_DIR=/path/to/vllm-deploy/run
LOG_DIR=/path/to/vllm-deploy/logs

VLLM_NO_USAGE_STATS=1
