CONDA_ENV=vllm-prefetch
VLLM_REPO=/path/to/vllm-cache-prefetch
CUDA_HOME=/usr/local/cuda

SERVICE_NAME=vllm-qwen3vl-8b
CUDA_VISIBLE_DEVICES=0

MODEL_PATH=/path/to/qwen3-vl-8b
SERVED_MODEL_NAME=qwen3vl-8b

HOST=0.0.0.0
PORT=8000

TENSOR_PARALLEL_SIZE=1
DTYPE=bfloat16
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=65536
TRUST_REMOTE_CODE=1
TASK=
ALLOWED_LOCAL_MEDIA_PATH=/path/to/vispage-artifact-release

EXTRA_VLLM_ARGS=

VLLM_AM_ENCODER_CACHE_SIZE=65536
VLLM_AM_ENCODER_CACHE_RESERVE=16384
VLLM_AM_ENCODER_CPU_CACHE_GB=16

RUN_DIR=/path/to/vllm-deploy/run
LOG_DIR=/path/to/vllm-deploy/logs

VLLM_NO_USAGE_STATS=1
