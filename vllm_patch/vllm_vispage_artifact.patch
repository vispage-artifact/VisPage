+    @staticmethod
+    def _new_am_model_trace(
+        scheduler_output: "SchedulerOutput",
+    ) -> dict[str, Any] | None:
+        if not scheduler_output.am_timeline_events:
+            return None
+        scheduled_encoder_inputs = scheduler_output.scheduled_encoder_inputs
+        return {
+            "runner_execute_start_mono_ms": time.monotonic() * 1000,
+            "runner_total_scheduled_tokens": (
