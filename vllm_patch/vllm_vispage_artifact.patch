+    @staticmethod
+    def _am_trace_add_cpu_ms(
+        am_trace: dict[str, Any] | None,
+        key: str,
+        start_mono_ms: float,
+    ) -> None:
+        if am_trace is None:
+            return
+        elapsed_ms = time.monotonic() * 1000 - start_mono_ms
+        am_trace[key] = float(am_trace.get(key, 0.0)) + elapsed_ms
+
+    @staticmethod
+    def _am_trace_cuda_start(
+        am_trace: dict[str, Any] | None,
+        key: str,
+    ) -> tuple[str, torch.cuda.Event, torch.cuda.Event] | None:
+        if am_trace is None or not torch.cuda.is_available():
+            return None
+        start_event = torch.cuda.Event(enable_timing=True)
+        end_event = torch.cuda.Event(enable_timing=True)
+        start_event.record()
+        return key, start_event, end_event
+
+    @staticmethod
+    def _am_trace_cuda_end(
+        am_trace: dict[str, Any] | None,
+        event_pair: tuple[str, torch.cuda.Event, torch.cuda.Event] | None,
+    ) -> None:
+        if am_trace is None or event_pair is None:
+            return
+        _, _, end_event = event_pair
+        end_event.record()
+        am_trace.setdefault("_cuda_event_pairs", []).append(event_pair)
+
+    @staticmethod
+    def _finalize_am_model_trace(
+        am_trace: dict[str, Any] | None,
+    ) -> dict[str, Any] | None:
+        if am_trace is None:
+            return None
+        for key, start_event, end_event in am_trace.pop(
+            "_cuda_event_pairs", []
+        ):
+            end_event.synchronize()
+            am_trace[key] = float(am_trace.get(key, 0.0)) + float(
+                start_event.elapsed_time(end_event)
+            )
+        am_trace["runner_execute_end_mono_ms"] = time.monotonic() * 1000
+        start_ms = am_trace.get("runner_execute_start_mono_ms")
+        if start_ms is not None:
+            am_trace["runner_execute_wall_ms"] = (
+                am_trace["runner_execute_end_mono_ms"] - float(start_ms)
+            )
+        return am_trace
