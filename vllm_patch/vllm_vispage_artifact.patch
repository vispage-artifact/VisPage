+    @staticmethod
+    def _encoder_cpu_entry_pending(entry: AMEncoderCPUCacheEntry) -> bool:
+        if entry.offload_event is not None and not entry.offload_event.query():
+            return True
+        if entry.restore_event is not None and not entry.restore_event.query():
+            return True
+        return False
