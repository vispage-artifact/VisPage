+    def protect(self, request: Request, input_id: int) -> None:
+        """Protect a cached background encoder output with LRU eviction.
+
+        Protection is used by Agent Memory background prewarm. A protected entry
+        is not part of the normal freeable LRU once its request finishes, but it
+        can still be evicted under encoder-cache pressure. This prevents
+        background image embeddings from blocking foreground/residual inputs
+        indefinitely.
+        """
+        mm_hash = request.mm_features[input_id].identifier
+        if mm_hash not in self.cached:
+            return
+        num_encoder_embeds = request.get_num_encoder_embeds(input_id)
+        if mm_hash in self.freeable:
+            self.freeable.pop(mm_hash)
+            self.num_freeable_slots -= num_encoder_embeds
+        self.protected[mm_hash] = num_encoder_embeds
+        self.protected.move_to_end(mm_hash)
+
+    def pin(self, request: Request, input_id: int) -> None:
+        self.protect(request, input_id)
+
+    def is_pinned(self, request: Request, input_id: int) -> bool:
