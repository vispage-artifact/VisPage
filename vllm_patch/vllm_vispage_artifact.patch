+                    am_trace, "encoder_cpu_offload_over_capacity_count", 1
+                )
+                break
+            evicted_hash, evicted = evicted_item
+            del self.encoder_cpu_cache[evicted_hash]
+            self.encoder_cpu_cache_bytes -= evicted.num_bytes
