+        self.encoder_cpu_cache[mm_hash] = AMEncoderCPUCacheEntry(
+            cpu_tensor=cpu_output,
+            num_bytes=item_bytes,
+            offload_event=offload_event,
+        )
+        self.encoder_cpu_cache_bytes += item_bytes
+
+        while self.encoder_cpu_cache_bytes > self.encoder_cpu_cache_capacity_bytes:
+            evicted_item: tuple[str, AMEncoderCPUCacheEntry] | None = None
+            for candidate_hash, candidate in self.encoder_cpu_cache.items():
+                self._refresh_encoder_cpu_entry(candidate)
+                if candidate_hash == mm_hash:
+                    continue
+                if self._encoder_cpu_entry_pending(candidate):
+                    continue
+                evicted_item = (candidate_hash, candidate)
+                break
