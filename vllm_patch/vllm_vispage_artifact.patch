+        self._trace_am_counter(am_trace, "encoder_cpu_offload_count", 1)
+        self._trace_am_counter(am_trace, "encoder_cpu_offload_async_count", 1)
+        self._trace_am_counter(am_trace, "encoder_cpu_offload_bytes", item_bytes)
+        self._am_trace_add_cpu_ms(
+            am_trace, "encoder_cpu_offload_cpu_ms", offload_start_ms
