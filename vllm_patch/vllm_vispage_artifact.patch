+    def start_am_encoder_restore(self, mm_hash: str) -> dict[str, Any]:
+        """Submit an async CPU->GPU restore for an AM encoder cache item.
+
+        This is intentionally non-blocking: it does not wait for the copy and
+        does not install the pending tensor in encoder_cache. The foreground
+        request will wait on the recorded CUDA event when it actually consumes
+        the encoder output.
+        """
+        restore_start_ms = time.monotonic() * 1000
+        available, restore_started = self._submit_encoder_cache_restore_from_cpu(
+            mm_hash
+        )
+        entry = self.encoder_cpu_cache.get(mm_hash)
+        state = "missing"
+        if mm_hash in self.encoder_cache:
+            state = "gpu"
+        elif entry is not None:
+            if entry.restore_event is not None and not entry.restore_event.query():
+                state = "restoring"
+            elif entry.restore_tensor is not None:
+                state = "restored"
+            else:
+                state = "cpu"
+        return {
+            "mm_hash": mm_hash,
+            "available": available,
+            "restore_started": restore_started,
+            "encoder_state": state,
+            "cpu_cache_bytes": self.encoder_cpu_cache_bytes,
+            "cpu_ms": time.monotonic() * 1000 - restore_start_ms,
+        }
+
+    def _restore_encoder_cache_from_cpu(
+        self,
+        mm_hash: str,
+        am_trace: dict[str, Any] | None = None,
+    ) -> bool:
+        restore_start_ms = time.monotonic() * 1000
+        available, _ = self._submit_encoder_cache_restore_from_cpu(
+            mm_hash, am_trace
