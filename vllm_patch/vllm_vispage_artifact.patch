new file mode 100644
index 000000000..2cfb66980
--- /dev/null
+++ b/vllm/v1/core/am_cache_registry.py
@@ -0,0 +1,170 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+
+import time
+from dataclasses import dataclass, field
+from typing import Any
+
+
+@dataclass
+class AMCacheEntry:
+    cache_key: str
+    role: str
+    state: str = "warming"
+    prompt_tokens: int = 0
+    cached_tokens: int = 0
+    live_blocks: int = 0
+    evicted_blocks: int = 0
+    last_event: str = "queued"
+    last_update_ms: float = field(default_factory=lambda: time.time() * 1000)
+    last_encoder_event: str | None = None
+    last_encoder_update_ms: float = 0.0
+
+    def to_dict(self) -> dict[str, Any]:
+        return {
+            "cache_key": self.cache_key,
+            "role": self.role,
+            "state": self.state,
+            "ready": self.state == "ready",
+            "prompt_tokens": self.prompt_tokens,
+            "cached_tokens": self.cached_tokens,
+            "live_blocks": self.live_blocks,
+            "evicted_blocks": self.evicted_blocks,
+            "last_event": self.last_event,
+            "last_update_ms": self.last_update_ms,
+            "last_encoder_event": self.last_encoder_event,
+            "last_encoder_update_ms": self.last_encoder_update_ms,
+        }
+
+
+class AMCacheRegistry:
+    """Lightweight Agent Memory cache state registry.
+
+    This registry tracks AM cache keys at the KV block level. It is intentionally
+    conservative: a key is downgraded when any registered KV block is overwritten
+    by the block pool, so an external agent can avoid assuming a prefetched
+    memory is still fully available.
+    """
+
+    def __init__(self) -> None:
+        self._entries: dict[str, AMCacheEntry] = {}
+        self._block_to_key: dict[int, str] = {}
+        self._block_tokens: dict[int, int] = {}
+
+    def register_request(self, cache_key: str, role: str, prompt_tokens: int) -> None:
+        entry = self._entries.get(cache_key)
+        if entry is None:
+            self._entries[cache_key] = AMCacheEntry(
+                cache_key=cache_key,
+                role=role,
+                prompt_tokens=prompt_tokens,
+            )
+            return
+        entry.role = role
+        entry.prompt_tokens = max(entry.prompt_tokens, prompt_tokens)
+        entry.last_event = "queued"
+        entry.last_update_ms = time.time() * 1000
+        if entry.state == "evicted":
+            entry.state = "warming"
+
+    def register_cached_block(
+        self,
+        cache_key: str,
+        role: str,
+        prompt_tokens: int,
+        block_id: int,
+        block_tokens: int,
+    ) -> None:
+        entry = self._entries.get(cache_key)
+        if entry is None:
+            entry = AMCacheEntry(
+                cache_key=cache_key,
+                role=role,
+                prompt_tokens=prompt_tokens,
+            )
+            self._entries[cache_key] = entry
+
+        previous_key = self._block_to_key.get(block_id)
+        if previous_key == cache_key:
+            return
+        if previous_key is not None:
+            self._evict_block_id(block_id, "kv_block_reassigned")
+
+        self._block_to_key[block_id] = cache_key
+        self._block_tokens[block_id] = block_tokens
+        entry.role = role
+        entry.prompt_tokens = max(entry.prompt_tokens, prompt_tokens)
+        entry.live_blocks += 1
+        entry.cached_tokens += block_tokens
+        if entry.state == "evicted":
+            entry.state = "partial"
+        entry.last_event = "kv_block_cached"
+        entry.last_update_ms = time.time() * 1000
+
+    def mark_ready(self, cache_key: str, prompt_tokens: int) -> None:
+        entry = self._entries.get(cache_key)
+        if entry is None:
+            entry = AMCacheEntry(cache_key=cache_key, role="unknown")
+            self._entries[cache_key] = entry
+        entry.prompt_tokens = max(entry.prompt_tokens, prompt_tokens)
+        if entry.live_blocks > 0:
+            entry.state = "ready"
+        else:
+            entry.state = "partial"
+        entry.last_event = "prefill_ready"
+        entry.last_update_ms = time.time() * 1000
+
+    def evict_block(self, block_id: int) -> None:
+        self._evict_block_id(block_id, "kv_block_evicted")
+
+    def mark_encoder_evicted(self, cache_key: str) -> None:
+        """Record encoder-cache eviction without changing KV readiness.
+
+        AM `state` is intentionally KV-only. A missing GPU encoder tensor can
+        hurt requests whose remaining prefill range overlaps image tokens, but
+        it does not mean registered decoder KV blocks were lost.
+        """
+        entry = self._entries.get(cache_key)
+        if entry is None:
+            entry = AMCacheEntry(cache_key=cache_key, role="unknown")
+            self._entries[cache_key] = entry
+        entry.last_encoder_event = "encoder_cache_evicted"
+        entry.last_encoder_update_ms = time.time() * 1000
+
+    def _evict_block_id(self, block_id: int, event: str) -> None:
+        cache_key = self._block_to_key.pop(block_id, None)
+        block_tokens = self._block_tokens.pop(block_id, 0)
+        if cache_key is None:
+            return
+        entry = self._entries.get(cache_key)
+        if entry is None:
+            return
+        entry.live_blocks = max(0, entry.live_blocks - 1)
+        entry.evicted_blocks += 1
+        entry.cached_tokens = max(0, entry.cached_tokens - block_tokens)
+        entry.state = "evicted" if entry.live_blocks == 0 else "partial"
+        entry.last_event = event
+        entry.last_update_ms = time.time() * 1000
+
+    def get_status(self, cache_key: str) -> dict[str, Any]:
+        entry = self._entries.get(cache_key)
+        if entry is None:
+            return {
+                "cache_key": cache_key,
+                "state": "missing",
+                "ready": False,
+                "prompt_tokens": 0,
+                "cached_tokens": 0,
+                "live_blocks": 0,
+                "evicted_blocks": 0,
+                "last_event": "missing",
+                "last_update_ms": time.time() * 1000,
+                "last_encoder_event": None,
+                "last_encoder_update_ms": 0.0,
+            }
+        return entry.to_dict()
+
+    def reset(self) -> None:
+        self._entries.clear()
+        self._block_to_key.clear()
+        self._block_tokens.clear()
