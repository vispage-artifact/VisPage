+        return mm_hash in self.cached
+
+    def touch(self, mm_hash: str) -> bool:
+        """Refresh protected-entry LRU order for a selected cache key."""
+        if mm_hash not in self.cached or mm_hash not in self.protected:
+            return False
+        self.protected.move_to_end(mm_hash)
+        return True
