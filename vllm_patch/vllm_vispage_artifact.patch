+    def _clear_encoder_cpu_cache(self) -> None:
+        if self.encoder_cpu_offload_stream is not None:
+            self.encoder_cpu_offload_stream.synchronize()
+        if self.encoder_cpu_restore_stream is not None:
+            self.encoder_cpu_restore_stream.synchronize()
