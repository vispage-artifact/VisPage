+        item_bytes = self._tensor_nbytes(output)
+        cpu_output = torch.empty(
+            output.shape,
+            dtype=output.dtype,
+            device="cpu",
+            pin_memory=True,
+        )
+        offload_event = torch.cuda.Event()
+        current_stream = torch.cuda.current_stream(device=self.device)
+        with torch.cuda.stream(self.encoder_cpu_offload_stream):
+            self.encoder_cpu_offload_stream.wait_stream(current_stream)
