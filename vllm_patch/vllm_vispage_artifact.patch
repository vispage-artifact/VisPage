+        entry = self.encoder_cpu_cache[mm_hash]
+        if entry.restore_event is not None:
+            torch.cuda.current_stream(device=self.device).wait_event(entry.restore_event)
+        self.encoder_cache[mm_hash] = entry.restore_tensor
+        if entry.restore_event is None or entry.restore_event.query():
+            entry.restore_tensor = None
+        self._trace_am_counter(am_trace, "encoder_cpu_restore_count", 1)
+        self._trace_am_counter(
+            am_trace, "encoder_cpu_restore_bytes", entry.num_bytes
+        )
+        self._trace_am_list(am_trace, "encoder_cpu_restore_hashes", mm_hash)
+        self._am_trace_add_cpu_ms(
+            am_trace, "encoder_cpu_restore_cpu_ms", restore_start_ms
+        )
+        return True
