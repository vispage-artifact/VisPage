+        if self.encoder_cpu_cache_capacity_bytes <= 0:
+            return
+
+        offload_start_ms = time.monotonic() * 1000
+        old = self.encoder_cpu_cache.pop(mm_hash, None)
+        if old is not None:
+            if self._encoder_cpu_entry_pending(old):
+                if old.offload_event is not None:
+                    old.offload_event.synchronize()
+                if old.restore_event is not None:
+                    old.restore_event.synchronize()
