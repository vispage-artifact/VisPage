+    def _ensure_encoder_cpu_streams(self) -> None:
+        if self.encoder_cpu_offload_stream is None:
+            self.encoder_cpu_offload_stream = torch.cuda.Stream(device=self.device)
+        if self.encoder_cpu_restore_stream is None:
+            self.encoder_cpu_restore_stream = torch.cuda.Stream(device=self.device)
